{
  "name": "catdetector-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "check": "npm run lint && npm run typecheck",
    "test": "vitest run"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@testing-library/svelte": "^5.2.9",
    "@types/node": "^25.9.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.7.4",
    "svelte-check": "^4.4.6",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.16"
  }
}
